##:kivy
#:import wb webbrowser
#: set cor_borda 153/255, 51/255, 1, 1

<BoxMain>
    button_refresh: button_refresh
    # button_bottomtop: button_bottomtop
    checkbox_auto: checkbox_auto
    scrollview_streams: scrollview_streams
    grid_streams: grid_streams
    orientation: 'vertical'
    md_bg_color: self.theme_cls.backgroundColor

    MDTopAppBar:
        type: "small"
        md_bg_color: self.theme_cls.surfaceContainerLowColor

        MDTopAppBarLeadingButtonContainer:
            MDActionTopAppBarButton:
                icon: "refresh"
                id: button_refresh
                on_release: root.refresh_streams_on()

        MDTopAppBarTrailingButtonContainer:
            MDBoxLayout:
                orientation: "horizontal"
                adaptive_width: True
                spacing: "4dp"
                MDLabel:
                    text: "Auto"
                    adaptive_width: True
                    theme_text_color: "Secondary"
                    font_style: "Label"
                    role: "small"
                MDCheckbox:
                    id: checkbox_auto
                    active: True
                    size_hint: None, None
                    size: "32dp", "32dp"
                    pos_hint: {"center_y": .5}
            
            MDActionTopAppBarButton:
                id: button_bottomtop
                icon: "arrow-up-down-bold-outline"
                on_release: root.bottomtop()

            MDActionTopAppBarButton:
                icon: "theme-light-dark"
                on_release: app.toggle_theme()

            MDActionTopAppBarButton:
                icon: "logout"
                on_release: app.root.logout()

    ScrollView:
        id: scrollview_streams
        scroll_wheel_distance: 200
        always_overscroll: False

        MDBoxLayout:
            orientation: 'vertical'
            adaptive_height: True
            padding: 0, "10dp"
            
            MDGridLayout:
                id: grid_streams
                cols: 3
                adaptive_height: True
                spacing: "12dp"
                padding: "12dp"
            
            MDButton:
                style: "filled"
                pos_hint: {"center_x": .5}
                on_release: root.add_more_streams()
                MDButtonText:
                    text: "Ver mais"
