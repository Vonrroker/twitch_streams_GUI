<BoxStream>
    orientation: "vertical"
    size_hint_y: None
    height: self.width * 9/16 + dp(72)
    style: "elevated"
    theme_bg_color: "Custom"
    md_bg_color: self.theme_cls.surfaceContainerLowColor
    radius: "12dp"
    ripple_behavior: False
    on_release: app.root.play(root.stream)
    theme_shadow_color: "Custom"
    shadow_color: .392, .255, .647, 1
    theme_bg_color: "Custom"
    theme_shadow_offset: "Custom"
    shadow_offset: (1, -1)
    theme_shadow_softness: "Custom"
    shadow_softness: 1
    theme_elevation_level: "Custom"
    elevation_level: 2


    MDRelativeLayout:
        size_hint: 1, None
        height: root.width * 9/16

        FitImage:
            source: root.preview_img
            radius: "12dp", "12dp", 0, 0
            size_hint: 1, 1
            mipmap: True
            nocache: False

        MDButton:
            style: "filled"
            pos_hint: {"top": .92, "x": .05}
            size_hint: None, None
            size: "44dp", "24dp"
            md_bg_color: 1, 0, 0, .9
            radius: "4dp"
            ripple_behavior: False
            MDButtonText:
                text: "LIVE"
                font_style: "Label"
                role: "small"
                bold: True
                pos_hint: {"center_x": .5, "center_y": .5}

        MDIconButton:
            icon: "information-outline"
            pos_hint: {"top": 1, "right": 1}
            theme_icon_color: "Custom"
            icon_color: 1, 1, 1, .8
            on_release: root.info()

        MDLabel:
            id: label_status
            text: ""
            opacity: 0
            halign: "center"
            valign: "center"
            theme_text_color: "Custom"
            text_color: 1, 1, 1, 1
            md_bg_color: 0, 0, 0, .7
            radius: "8dp"
            padding: "10dp"
            size_hint: .9, .8
            pos_hint: {"center_x": .5, "center_y": .5}

    MDBoxLayout:
        orientation: "vertical"
        padding: "12dp", "8dp", "12dp", "12dp"
        spacing: "4dp"

        MDLabel:
            text: root.channel_name
            font_style: "Title"
            role: "medium"
            bold: True

        MDLabel:
            text: root.game
            font_style: "Label"
            role: "large"
            theme_text_color: "Secondary"

        MDBoxLayout:
            orientation: "horizontal"
            spacing: "4dp"
            size_hint_y: None
            height: "20dp"

            MDIcon:
                icon: "account-group"
                size_hint: None, None
                size: "16dp", "16dp"
                pos_hint: {"center_y": .5}
                theme_icon_color: "Secondary"

            MDLabel:
                text: root.viewers_count
                font_style: "Label"
                role: "medium"
                theme_text_color: "Secondary"
